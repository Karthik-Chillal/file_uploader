<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>File Uploader</title>
  </head>
  <body>
    <h1>File Uploader</h1>
    <h2>Welcome back, <%= currentUser.username %>!</h2>
    <a href="/logout">Logout</a>
    <br />
    <a href="<%= backFolderId ? '/folders/' + backFolderId : '/home' %>">back</a>
    <%- include('./partials/fileForm.ejs', {currentFolderId: currentFolderId}) %> <%-
    include('./partials/folderForm.ejs', {currentFolderId: currentFolderId}) %> <%-
    include('./partials/displayFolders.ejs', {folders: folders}) %>
    <%- include('./partials/displayFiles.ejs', {files: files}) %>
  </body>
</html>
